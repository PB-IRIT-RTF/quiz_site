{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Frontend: dev",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "VITE_API_MODE": "http",
          "VITE_API_BASE": "http://127.0.0.1:8000"
        }
      },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Frontend: build",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Local deploy: one process (build frontend)",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Local deploy: one process (run backend)",
      "type": "shell",
      "command": "${command:python.interpreterPath}",
      "args": ["-m", "uvicorn", "app.main:app", "--host", "127.0.0.1", "--port", "8000"],
      "options": {
        "cwd": "${workspaceFolder}/backend",
        "env": {
          "DEMO_SEED": "true"
        }
      },
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Local deploy: one process (build + run)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Local deploy: one process (build frontend)",
        "Local deploy: one process (run backend)"
      ],
      "problemMatcher": []
    }
  ]
}
