# Backend example env
APP_NAME="Universe Quiz"
ENVIRONMENT=prod

DATABASE_URL=sqlite+aiosqlite:///./data/quiz.db

# IMPORTANT: set to a random secret in production
COOKIE_SECRET=change-me-to-a-long-random-secret
COOKIE_SECURE=true

# comma-separated origins (frontend dev server)
# важно добавить и localhost и 127.0.0.1, иначе браузер будет блокировать запросы по CORS
FRONTEND_ORIGINS=https://example.com

# Quiz window defaults for demo seeding (optional)
DEMO_SEED=false

# Demo admin user (created by seed when DEMO_SEED=true)
# username is fixed: admin
DEMO_ADMIN_PASSWORD=change-me

# Admin login brute-force protection
ADMIN_LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
ADMIN_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10
ADMIN_LOGIN_RATE_LIMIT_BLOCK_SECONDS=900

# Allowed hosts for iframe embed media
EMBED_ALLOWED_HOSTS=vk.com,www.vk.com,rutube.ru,www.rutube.ru,player.vimeo.com,dzen.ru,www.dzen.ru
