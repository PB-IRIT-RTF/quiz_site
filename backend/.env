# Backend example env
APP_NAME="Universe Quiz"
ENVIRONMENT=dev

DATABASE_URL=sqlite+aiosqlite:///./data/quiz.db
REDIS_URL=redis://localhost:6379/0

# IMPORTANT: set to a random secret in production
COOKIE_SECRET=dev-secret-change-me
COOKIE_SECURE=false

# comma-separated origins (frontend dev server)
# важно добавить и localhost и 127.0.0.1, иначе браузер будет блокировать запросы по CORS
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Quiz window defaults for demo seeding (optional)
DEMO_SEED=true

# Demo admin user (created by seed when DEMO_SEED=true)
# username is fixed: admin
DEMO_ADMIN_PASSWORD=admin
